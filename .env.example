APP_ENV=local
APP_PORT=8888
DEBUG=true

# For Cloud Run deploy: can be left empty if secret already exists in Secret Manager.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DBNAME=marzlive_upgrade

# For Cloud Run deploy: can be left empty if secrets already exist in Secret Manager.
COOKIE_SECRET=change-me
PASSWORD_SALT=change-me

MEDIA_BACKEND=local
MEDIA_LOCAL_ROOT=./data/media
MEDIA_PUBLIC_BASE_URL=http://localhost:8080/media

GCS_PROJECT_ID=
GCS_BUCKET=
GCS_SIGNED_URL_TTL_SECONDS=3600
GOOGLE_APPLICATION_CREDENTIALS=

AUTH_COOKIE_NAME=ml_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL_DAYS=14

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_PROJECT_ID=
RECAPTCHA_MIN_SCORE=0.5

BULLETIN_PUBSUB_ENABLED=false
BULLETIN_PROJECT_ID=
BULLETIN_TOPIC_ID=
BULLETIN_SUBSCRIPTION_ID=
